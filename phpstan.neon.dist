parameters:
    level: 5
    strictRules:
        dynamicCallOnStaticMethod: false
    paths:
        - src
        - config
        - database
    checkOctaneCompatibility: true
    checkModelProperties: true
    ignoreErrors:
        # Config files use env() by design
        - identifier: larastan.noEnvCallsOutsideOfConfig
        # Testing infrastructure: Machine::$machineFakes static private access
        - identifier: staticClassAccess.privateProperty
        # Package traits used by consumers, not within src/
        - identifier: trait.unused
        # Mockery return type issues in Fakeable trait
        - identifier: return.type
          path: src/Traits/Fakeable.php
        # Intentional default cases in match expressions
        - identifier: match.unhandled
        # Defensive strict comparisons (always false by design)
        - identifier: identical.alwaysFalse
        # Eloquent dynamic properties from raw queries
        - identifier: property.notFound
        # Eloquent magic methods on models
        - identifier: method.notFound
        # PHPDoc type hints for Laravel static factories (@var Machine)
        - identifier: varTag.nativeType
        - identifier: return.phpDocType
        # Spatie Laravel Data attribute target issues
        - identifier: attribute.target
        # Laravel covariant return types
        - identifier: method.childReturnType
