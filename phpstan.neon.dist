parameters:
    level: 6
    strictRules:
        dynamicCallOnStaticMethod: false
    paths:
        - src
        - config
        - database
    checkOctaneCompatibility: true
    checkModelProperties: true
    ignoreErrors:
        # Config files use env() by design — only allowed in config/
        - identifier: larastan.noEnvCallsOutsideOfConfig
          path: config/

        # Fakeable trait: Mockery return types
        - identifier: return.type
          path: src/Traits/Fakeable.php
        # Package traits — used by consumers, not within src/
        - identifier: trait.unused
          path: src/Testing/
        - identifier: trait.unused
          path: src/Traits/

        # Defensive identical comparisons — intentional guard clauses
        - identifier: identical.alwaysFalse
          path: src/Definition/StateDefinition.php
        - identifier: identical.alwaysFalse
          path: src/Commands/MachineConfigValidatorCommand.php

        # Eloquent raw query dynamic properties
        - identifier: property.notFound
          path: src/Commands/ArchiveStatusCommand.php
        - identifier: property.notFound
          path: src/Exceptions/MachineLockTimeoutException.php

        # Eloquent magic methods
        - identifier: method.notFound
          path: src/Behavior/InvokableBehavior.php
        - identifier: method.notFound
          path: src/Casts/MachineCast.php

        # Laravel covariant return types
        - identifier: method.childReturnType
          path: src/Actor/Machine.php
        - identifier: method.childReturnType
          path: src/Models/MachineEvent.php

        # Spatie Data collect() override: generic types cannot be specified in PHP union return types
        - identifier: missingType.generics
          path: src/Behavior/EventBehavior.php

        # Intentional narrowing of parent method parameter types
        - identifier: method.childParameterType
          path: src/ContextManager.php
        - identifier: method.childParameterType
          path: src/Models/MachineEvent.php

